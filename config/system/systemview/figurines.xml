		<!-- <transitionSpeed>750</transitionSpeed> -->
		<logoPos>0.15 0.5</logoPos>
		<logoPos ifHelpPrompts="false">0.15 0.53</logoPos>
		<imageSource>thumbnail</imageSource>
		<defaultTransition>instant</defaultTransition>
		<!-- <logoRotation>1</logoRotation> -->
		<!-- <logoRotationOrigin>0 1</logoRotationOrigin> -->
		<maxLogoCount>11</maxLogoCount>
		<itemTemplate>
			<container>
				<image name="shadow_figurine">
					<pos>0.5 0.54</pos>
					<origin>0.5 0.5</origin>
					<maxSize>0.55 0.55</maxSize>
					<path>"${themePath}/art/figurines/" + {system:theme} + ".png"</path>
					<saturation>1</saturation>
					<zIndex>5</zIndex>
					<padding>3 3 -3 -3</padding>
					<color>000000</color>
					<storyboard event="activate" repeatAt="1000">
						<animation property="offsetY"  to="-0.015" begin="500"   duration="300" mode="Bump"/>
						<animation property="offsetY"  to="-0.035" begin="7000"  duration="300" mode="Bump"   autoreverse="true"/>
						<animation property="offsetX"  to="0.005"   begin="19000" duration="200" mode="Bump"   repeat="2" autoreverse="true"/>
					</storyboard>
				</image>
				<image name="figurine">
					<pos>0.5 0.54</pos>
					<origin>0.5 0.5</origin>
					<maxSize>0.55 0.55</maxSize>
					<path>"${themePath}/art/figurines/" + {system:theme} + ".png"</path>
					<saturation>0.9</saturation>
					<zIndex>6</zIndex>
					<storyboard event="activate" repeatAt="1000">
						<animation property="offsetY" to="-0.015"  begin="500"   duration="300" mode="Bump"/>
						<animation property="offsetY" to="-0.035"  begin="7000"  duration="300" mode="Bump"   autoreverse="true"/>
						<animation property="offsetX"  to="0.005"   begin="19000" duration="200" mode="Bump"   repeat="2" autoreverse="true"/>
					</storyboard>
				</image>
				<image name="shadow_logo">
					<pos>0.5 0.9</pos>
					<origin>0.5 0.5</origin>
					<maxSize>0.2 1</maxSize>
					<path>{system:logo}</path>
					<padding>3 3 -3 -3</padding>
					<color>000000</color>
					<zIndex>7</zIndex>
					<storyboard event="activate">
						<animation property="offsetY" to="-0.015" begin="500" duration="300" mode="EaseInOut"/>
					</storyboard>
				</image>
				<image name="logo">
					<pos>0.5 0.9</pos>
					<origin>0.5 0.5</origin>
					<maxSize>0.2 1</maxSize>
					<path>{system:logo}</path>
					<zIndex>8</zIndex>
					<storyboard event="activate">
						<animation property="offsetY" to="-0.015" begin="500" duration="300" mode="EaseInOut"/>
					</storyboard>
				</image>
			</container>
		</itemTemplate>
