	</text>
		
		
	  <text name="systemInfoEx" ifSubset="InfoCustomView:detailed" extra="static">
		 <text>{system:total} ${GamesNumber} • {system:gamesPlayed} ${NumberPlayed} • {system:favorites} ${GamesFavs}</text>
		 <visible>{system:total} &gt; 0 ? 1 : 0</visible>
	  </text>
	  
      <text name="systemInfoEx2" ifSubset="InfoCustomView:detailed" extra="static">
         <text>${theme.mostplayed} {system:mostPlayed}</text>
         <opacity>0</opacity>
		 <color>f9ffa1</color>
         <visible>{system:total} &gt; 0 ? 1 : 0</visible>
      </text>

      <text name="systemInfoExNull" ifSubset="InfoCustomView:detailed" extra="static">
         <text>0 ${GameNumber}</text>
         <visible>{system:total} == 0 ? 1 : 0</visible>
      </text>

      <control name="systemInfoEx">
         <storyboard repeat="forever">
            <animation property="opacity" from="1" to="0" begin="3000" duration="350" mode="easeOut" />
            <animation property="offsetY" to="-0.02" begin="3000" duration="350" mode="easeOut" />
            <animation property="opacity" from="0" to="1" begin="6000" duration="350" mode="easeIn" />
            <animation property="offsetY" to="0" begin="6000" duration="350" mode="easeOut" />
         </storyboard>
      </control>

      <control name="systemInfoEx2">
         <storyboard repeat="forever">
            <animation property="opacity" from="0" to="1" begin="3000" duration="350" mode="easeIn" />
            <animation property="offsetY" from="0.02" begin="3000" duration="350" mode="easeOut" />
            <animation property="opacity" from="1" to="0" begin="6000" duration="350" mode="easeOut" />
            <animation property="offsetY" to="0.02" begin="6000" duration="350" mode="easeIn" />
         </storyboard>
      </control>
		

	<image name="right_BottomFrame" extra="true">
		<visible ifHelpPrompts="false">false</visible>
	</image>
	
	
	<!-- position des vidéos preview quand elles sont affichées -->
    <video name="video-preview" ifSubset="video-preview:Show" extra="true">
		<path>{random}</path>
		<origin>0 0</origin>
		<delay>1.1</delay> 
		<effect>none</effect>
		<zIndex>31</zIndex>
				
		<roundCorners>0</roundCorners>
		<showSnapshotNoVideo>false</showSnapshotNoVideo>
		<showSnapshotDelay>false</showSnapshotDelay>
		<!-- <audio>false</audio> -->
		<!-- <default>${themePath}/art/divers/no-video.mp4</default> -->
		
		<shader>
			<path>${themePath}/art/shaders/border.glsl</path>
			<borderSize>0.013</borderSize>
			<borderColor>${baseColor}</borderColor>
		</shader>
		
		<maxSize>0.25 0.23</maxSize>	
		<maxSize ifHelpPrompts="false">0.25 0.25</maxSize>	
		<pos>0.03 0.26</pos>
    </video>
		
	
</view>

</theme>
