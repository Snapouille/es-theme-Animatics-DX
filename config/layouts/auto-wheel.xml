			<animation enabled="exists({game:video})" property="opacity" to="0" begin="1000" duration="250" mode="linear"/>
		</storyboard>
		<storyboard event="activate">
			<animation enabled="exists({game:video})" property="opacity" to="0" begin="1000" duration="250" mode="linear"/>
		</storyboard>
		<storyboard event="deactivate">
			<animation property="opacity" to="0" begin="" duration="" mode="linear"/>
